#!/usr/bin/env bash
# monitorvpn — управление probe-агентом xray-checker-statuspage на macOS.
#
#   monitorvpn start       запустить агента
#   monitorvpn stop        остановить
#   monitorvpn restart     перезапуск
#   monitorvpn status      статус + последние строки лога
#   monitorvpn logs        tail -f лога
#   monitorvpn delete      полностью удалить (plist + ~/.xrs-probe + symlink)
#
set -euo pipefail

LABEL="com.xrs.probe"
PLIST="${HOME}/Library/LaunchAgents/${LABEL}.plist"
LOG="${HOME}/Library/Logs/xrs-probe.log"
APP_DIR="${HOME}/.xrs-probe"
SYMLINK="/usr/local/bin/monitorvpn"

c_g(){ printf "\033[32m%s\033[0m\n" "$*"; }
c_y(){ printf "\033[33m%s\033[0m\n" "$*"; }
c_r(){ printf "\033[31m%s\033[0m\n" "$*"; }

domain="gui/$(id -u)"
target="${domain}/${LABEL}"

is_loaded(){ launchctl print "${target}" >/dev/null 2>&1; }

usage(){
  cat <<EOF
monitorvpn — управление probe-агентом xray-checker-statuspage

Команды:
  monitorvpn start         запустить агент (зарегистрировать LaunchAgent)
  monitorvpn stop          остановить
  monitorvpn restart       перезапустить
  monitorvpn status        показать статус и последние строки лога
  monitorvpn logs          tail -f лог-файла
  monitorvpn delete        полностью удалить (plist + ~/.xrs-probe/ + symlink)
EOF
}

cmd="${1:-status}"

case "${cmd}" in
  start)
    [ -f "${PLIST}" ] || { c_r "не найден ${PLIST}. Запусти install-macos.sh."; exit 1; }
    if is_loaded; then
      c_y "агент уже работает"
      exit 0
    fi
    if launchctl bootstrap "${domain}" "${PLIST}" 2>/dev/null; then
      c_g "✓ агент запущен"
    elif launchctl load "${PLIST}" 2>/dev/null; then
      c_g "✓ агент запущен (legacy load)"
    else
      c_r "не удалось загрузить LaunchAgent"
      exit 1
    fi
    ;;
  stop)
    if ! is_loaded; then
      c_y "агент не запущен"
      exit 0
    fi
    if launchctl bootout "${target}" 2>/dev/null; then
      c_g "✓ агент остановлен"
    elif launchctl unload "${PLIST}" 2>/dev/null; then
      c_g "✓ агент остановлен (legacy unload)"
    else
      c_r "не удалось остановить"
      exit 1
    fi
    ;;
  restart)
    "${0}" stop || true
    sleep 1
    "${0}" start
    ;;
  status)
    if is_loaded; then
      c_g "✓ агент работает (label: ${LABEL})"
    else
      c_r "✗ агент не запущен"
    fi
    if [ -f "${LOG}" ]; then
      echo
      c_y "Последние строки лога (${LOG}):"
      tail -n 5 "${LOG}"
    else
      c_y "лог-файл ещё не создан: ${LOG}"
    fi
    ;;
  logs|log|tail)
    [ -f "${LOG}" ] || { c_r "лог-файл не найден: ${LOG}"; exit 1; }
    tail -n 30 -f "${LOG}"
    ;;
  delete|uninstall|rm)
    c_y "Удаление…"
    is_loaded && (launchctl bootout "${target}" 2>/dev/null \
                  || launchctl unload "${PLIST}" 2>/dev/null) || true
    rm -f "${PLIST}"
    rm -rf "${APP_DIR}"
    # symlink удаляем, если на него есть права; иначе подсказка.
    if [ -L "${SYMLINK}" ]; then
      if rm -f "${SYMLINK}" 2>/dev/null; then
        c_g "  символическая ссылка ${SYMLINK} удалена"
      else
        c_y "  не могу удалить ${SYMLINK} без sudo:"
        echo "    sudo rm -f ${SYMLINK}"
      fi
    fi
    c_g "✓ удалено. Логи остались в ${LOG} (можешь снести вручную)."
    ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    c_r "неизвестная команда: ${cmd}"
    echo
    usage
    exit 2
    ;;
esac
